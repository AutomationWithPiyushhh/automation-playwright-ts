{
  "name": "automation-playwright-ts",
  "version": "1.0.0",
  "description": "A professional-grade Playwright TypeScript framework featuring custom utilities, Winston logging, and Allure reporting. Optimized for Web, API, and Electron testing.",
  "main": "index.js",
  "type": "commonjs",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AutomationWithPiyushhh/automation-playwright-ts.git"
  },
  "author": {
    "name": "Piyush Baldaniya",
    "url": "https://automationwithpiyush.vercel.app/"
  },
  "env": {
    "node": true,
    "browser": true
  },
  "lint-staged": {
    "*.{json,md,ts}": [
      "prettier --write"
    ],
    "*.{ts}": "eslint --fix"
  },
  "dependencies": {
    "@playwright/test": "^1.37.1",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "allure-commandline": "^2.23.1",
    "allure-playwright": "^2.5.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-jsdoc": "^46.4.6",
    "eslint-plugin-playwright": "^0.15.3",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.0",
    "prettier": "^3.0.2",
    "typescript": "5.1.6",
    "tslib": "^2.6.2",
    "winston": "^3.10.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --retries 0 --project=chromium",
    "test:chromium-headed": "playwright test -j 1 --retries 0 --headed --project=chromium",
    "test:reg": "playwright test --project=chromium -g '@reg'",
    "test:smoke": "playwright test --project=chromium -g '@smoke'",
    "report": "playwright show-report playwright-report",
    "ui": "playwright test --ui-port 0",
    "trace": "playwright show-trace --port 0",
    "allure": "allure generate ./allure-results --clean && allure open ./allure-report",
    "lint": "eslint \"tests/**/*.ts\" \"src/**/*.ts\" \"playwright.config.ts\"",
    "lint:fix": "eslint \"tests/**/*.ts\" \"src/**/*.ts\" \"playwright.config.ts\" --fix",
    "format": "prettier --write src tests testdata playwright.config.ts *.json",
    "prepare": "husky install",
    "postinstall": "playwright install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
